# ============================================
# Digital Wallet - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# ---- Django Settings ----
SECRET_KEY=your-super-secret-key-change-this
DEBUG=False

# ---- Supabase Database ----
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Use the "URI" format, replace [YOUR-PASSWORD] with your database password
# IMPORTANT: For Vercel serverless, use the POOLER connection string (port 6543)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ---- CORS Settings ----
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ---- Allowed Hosts ----
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# ---- For Local Development (optional) ----
# Leave DATABASE_URL empty to use SQLite locally
# DATABASE_URL=
